# Environment variables (contains secrets / deployment URLs)
.env
.env.local
.env.production

# Secret files — APNs keys, signing certs, anything that shouldn't
# ever land in git. Lives in .secrets/ (local-only), uploaded to
# GitHub Secrets via `gh secret set`.
.secrets/
*.p8
HEX_distribution.csr
HEX_distribution.key
distribution.p12
distribution.p12.base64
profile.base64

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Capacitor build artifacts (keep ios/ and android/ folders themselves)
ios/App/Pods/
ios/.xcode.env.local
android/.gradle/
android/app/build/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
